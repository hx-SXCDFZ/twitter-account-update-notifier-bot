# Required: target X username to monitor, without or with @.
# Default project target: ProbiusOfficial. Change this to monitor another account.
TARGET_USERNAME=ProbiusOfficial

# Optional: Docker image used by docker-compose.
# Pin this to a release tag for reproducible deployments.
DOCKER_IMAGE=ghcr.io/hx-sxcdfz/probiusofficial-x-reply-notifier:latest

# Optional: path to a Chrome executable when auto-detection is not enough.
# Windows example: C:/Program Files/Google/Chrome/Application/chrome.exe
# Docker default: /usr/bin/chromium
CHROME_BINARY=

# Optional: host proxy URL used by docker-compose for build and runtime traffic.
# Default target is the host machine's port 7890 from inside the container.
# Set this to an empty value if your network does not require a proxy.
HOST_PROXY_URL=http://host.docker.internal:7890

# Optional: Chrome runtime flags.
# Docker compose overrides these to true for container compatibility.
CHROME_HEADLESS=false
CHROME_NO_SANDBOX=false
CHROME_DISABLE_DEV_SHM_USAGE=false
CHROME_PROXY_SERVER=

# Optional: Chrome user data directory for reusing an existing login session.
# Leave empty to let the script create a temporary writable profile.
# Windows example: C:/Users/YourName/AppData/Local/Google/Chrome/User Data
CHROME_USER_DATA_DIR=

# Optional: Chrome profile directory name when CHROME_USER_DATA_DIR is set.
# Common values: Default, Profile 1
CHROME_PROFILE_DIRECTORY=

# Polling interval and jitter, in seconds.
CHECK_INTERVAL_SECONDS=60
CHECK_JITTER_SECONDS=10

# Selenium page load timeout, in seconds.
PAGE_LOAD_TIMEOUT_SECONDS=45

# Number of recent authored posts to track.
RECENT_POST_COUNT=5

# Local runtime files.
STATE_FILE=state/last_seen.json
LOG_FILE=logs/monitor.log
DIAGNOSTICS_DIR=diagnostics
DIAGNOSTICS_INTERVAL_SECONDS=300
DIAGNOSTICS_HTML_MAX_CHARS=500000

# Enable local beep alerts.
ENABLE_BEEP=true

# Optional: wait after opening the browser to allow manual login.
STARTUP_LOGIN_WAIT_SECONDS=0

# Optional webhook URLs. Keep these only in .env.
FEISHU_WEBHOOK=
DINGTALK_WEBHOOK=
